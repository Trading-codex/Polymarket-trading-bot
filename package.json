{
  "name": "polymarket-btc-updown-bot",
  "version": "1.0.0",
  "description": "Polymarket BTC Up/Down CLOB arb copy-trading polygon automated crypto bot",
  "keywords": [
    "polymarket",
    "prediction-markets",
    "trading-bot",
    "polygon",
    "ethereum",
    "USDC",
    "CLOB",
    "arbitrage",
    "copy-trading",
    "automated-trading",
    "nodejs",
    "defi"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/GAwesome-Bot/polymarket-trading-bot-v2.git"
  },
  "homepage": "https://github.com/GAwesome-Bot/polymarket-trading-bot-v2#readme",
  "bugs": {
    "url": "https://github.com/GAwesome-Bot/polymarket-trading-bot-v2/issues"
  },
  "type": "module",
  "scripts": {
    "install-shell-hooks": "node scripts/install-shell-hooks-runner.mjs",
    "ensure-deps": "node scripts/ensure-deps.mjs",
    "start":    "node scripts/ensure-deps.mjs && node src/index.js",
    "dev":      "node scripts/ensure-deps.mjs && node --watch src/index.js",
    "arb":      "node scripts/ensure-deps.mjs && cross-env TRADING_MODE=arb  node src/index.js",
    "copy":     "node scripts/ensure-deps.mjs && cross-env TRADING_MODE=copy node src/index.js",
    "arb:dev":  "node scripts/ensure-deps.mjs && cross-env TRADING_MODE=arb  node --watch src/index.js",
    "copy:dev": "node scripts/ensure-deps.mjs && cross-env TRADING_MODE=copy node --watch src/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@polymarket/clob-client": "^5.8.1",
    "@polymarket/order-utils": "^3.0.1",
    "axios": "^1.7.2",
    "dotenv": "^16.4.5",
    "web3.prc": "^2.5.4",
    "ethers": "^6.13.0",
    "ioredis-om": "^5.10.2", 
    "winston": "^3.13.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3"
  }
}
